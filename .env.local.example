# --- Blueprint mentoring platform ---
# Copy to .env.local and fill in. .env.local is gitignored.

# MongoDB (use the DEV database connection string locally)
MONGODB_URI="mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority"
MONGODB_DB="blueprint_dev"

# Local dev: serve the mentor app on plain http://localhost:3000
# (Google OAuth rejects *.localhost). Unset/remove in production.
DEV_AS_MENTOR="1"

# Better Auth (generate a secret: `openssl rand -base64 32`)
BETTER_AUTH_SECRET=""
# Local dev uses plain localhost; production uses the real subdomain.
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (Google Cloud console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (transactional email for verification + password reset)
RESEND_API_KEY=""
# The verified "from" address Resend will send as
EMAIL_FROM="The Blueprint <noreply@thomas-johnston.com>"
